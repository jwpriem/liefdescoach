{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "NODE_OPTIONS='--max-old-space-size=256' node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate-data": "tsx --tsconfig scripts/tsconfig.json scripts/migrate-to-neon.ts",
    "db:verify-migration": "tsx --tsconfig scripts/tsconfig.json scripts/verify-migration.ts",
    "db:seed-lessons": "tsx --tsconfig scripts/tsconfig.json scripts/seed-lessons.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:booking": "playwright test e2e/booking.spec.ts",
    "test:registration": "playwright test e2e/registration.spec.ts",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/sitemap": "^7.0.0",
    "@popperjs/core": "^2.11.8",
    "@tailwindcss/vite": "^4.0.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.6",
    "nodemailer": "^6.9.0",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.0.0",
    "v-calendar": "^3.1.2",
    "vue-chartjs": "^5.3.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.27",
    "@nuxt/fonts": "^0.11.0",
    "@playwright/test": "^1.58.1",
    "@types/bcryptjs": "^3.0.0",
    "dayjs-nuxt": "^2.1.9",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "h3": "^1.15.5",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
